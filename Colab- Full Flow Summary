# Write a startup script
worker_cmd = """
cd /app/backend  # ← adjust to your backend folder

celery -A app.celery_app worker \\
  --queues=photo \\
  --concurrency=2 \\
  --hostname=colab_photo_worker@%h \\
  --loglevel=INFO \\
  --without-heartbeat \\
  --without-gossip \\
  --without-mingle
"""

# Run in background, pipe logs to file
import subprocess, threading, time

proc = subprocess.Popen(
    ["bash", "-c", worker_cmd],
    stdout=subprocess.PIPE,
    stderr=subprocess.STDOUT,
    text=True,
    cwd="/app/backend"  # adjust
)

# Stream logs in a thread
def stream_logs():
    for line in proc.stdout:
        print(line, end="")

log_thread = threading.Thread(target=stream_logs, daemon=True)
log_thread.start()

time.sleep(8)
print("\n✅ Colab celery_photo worker started (PID:", proc.pid, ")")


