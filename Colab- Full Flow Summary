from celery import Celery

celery_app = Celery(broker=REDIS_URL, backend=REDIS_URL)

time.sleep(3)
inspect = celery_app.control.inspect(timeout=5)

workers = inspect.active_queues()
print("Registered workers:")
for worker, queues in (workers or {}).items():
    print(f"  {worker}:")
    for q in queues:
        print(f"    → queue: {q['name']}")


