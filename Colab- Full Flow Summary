import time

print("Monitoring photo queue... (Ctrl+C to stop)\n")
try:
    while True:
        pending  = r.llen("photo")
        inspect2 = celery_app.control.inspect(timeout=3)
        active   = inspect2.active() or {}

        active_tasks = []
        for w, tasks in active.items():
            for t in tasks:
                active_tasks.append(t.get("name", "unknown"))

        print(f"[{time.strftime('%H:%M:%S')}] Queued: {pending} | Active: {len(active_tasks)} {active_tasks}")
        time.sleep(5)
except KeyboardInterrupt:
    print("Stopped monitoring")


