def multi_scale_detect(img, scales=[0.5, 1.0, 1.5, 2.0]):
    """Detect faces at multiple scales for maximum coverage"""
    h, w = img.shape[:2]
    all_detections = []
    
    for scale in scales:
        if scale == 1.0:
            scaled_img = img
        else:
            new_w, new_h = int(w * scale), int(h * scale)
            scaled_img = cv2.resize(img, (new_w, new_h), interpolation=cv2.INTER_CUBIC)
        
        faces = face_app.get(scaled_img)
        
        # Scale bounding boxes back to original coordinates
        for face in faces:
            if scale != 1.0:
                face.bbox = [coord / scale for coord in face.bbox]
        
        all_detections.extend(faces)
    
    # Remove overlapping detections (NMS)
    return non_maximum_suppression(all_detections, iou_threshold=0.3)
```

