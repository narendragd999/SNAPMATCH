**Solution**:
```python
def handle_large_file(image_path, max_size_mb=15):
    """Downsample large files instead of rejecting them"""
    file_size_mb = os.path.getsize(image_path) / (1024 * 1024)
    
    if file_size_mb <= max_size_mb:
        return cv2.imread(image_path)
    
    # Smart downsample for large files
    img = cv2.imread(image_path, cv2.IMREAD_REDUCED_RESOLUTION_FACTOR_4)
    if img is not None:
        print(f"⚠ Downsampled large file ({file_size_mb:.1f}MB → {img.shape})")
        return img
    
    # Fallback: Use PIL for very large files (better memory handling)
    from PIL import Image
    pil_img = Image.open(image_path)
    
    # Calculate scale to fit in memory
    max_dimension = 4000  # Safe size
    ratio = min(max_dimension / pil_img.width, max_dimension / pil_img.height)
    
    if ratio < 1.0:
        new_size = (int(pil_img.width * ratio), int(pil_img.height * ratio))
        pil_img = pil_img.resize(new_size, Image.LANCZOS)
    
    return cv2.cvtColor(np.array(pil_img), cv2.COLOR_RGB2BGR)
```

