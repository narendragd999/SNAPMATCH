import os

# ── Fix: append ssl_cert_reqs to both Redis URLs ──────────────────────────────
def fix_redis_ssl(url):
    if url and url.startswith("rediss://") and "ssl_cert_reqs" not in url:
        sep = "&" if "?" in url else "?"
        return url + sep + "ssl_cert_reqs=CERT_NONE"
    return url

os.environ["CELERY_BROKER_URL"]      = fix_redis_ssl(os.environ.get("CELERY_BROKER_URL", ""))
os.environ["CELERY_RESULT_BACKEND"]  = fix_redis_ssl(os.environ.get("CELERY_RESULT_BACKEND", ""))

print("✓ Redis SSL fixed")
print(f"  BROKER  → {os.environ['CELERY_BROKER_URL'][-40:]}")
print(f"  BACKEND → {os.environ['CELERY_RESULT_BACKEND'][-40:]}")
