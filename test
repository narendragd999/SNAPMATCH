import subprocess, threading, time, os, sys

# ── 1. Detect CUDA ────────────────────────────────────────────────────────────
cuda_check = subprocess.run(["nvcc", "--version"], capture_output=True, text=True)
cuda_ver   = "12" if "release 12" in cuda_check.stdout else "11"
print(f"🖥  CUDA {cuda_ver}.x detected")

# ── 2. Install dependencies ───────────────────────────────────────────────────
DEPS = [
    f"faiss-gpu-cu{cuda_ver}",
    "celery[redis]",
    "sqlalchemy",
    "redis",
    "numpy<2",
    "insightface",
    "onnxruntime-gpu",
]

print("\n📦 Installing dependencies...")
failed = []
for pkg in DEPS:
    result = subprocess.run(
        [sys.executable, "-m", "pip", "install", "-q", pkg],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        print(f"  ✗  {pkg}\n     {result.stderr.strip()[:200]}")
        failed.append(pkg)
    else:
        print(f"  ✓  {pkg}")

if failed:
    raise SystemExit(f"Failed packages: {failed}")

# ── 3. Verify imports ─────────────────────────────────────────────────────────
print("\n🔍 Verifying imports...")
missing = []
for mod in ["faiss", "celery", "sqlalchemy", "redis", "numpy", "insightface"]:
    r = subprocess.run(
        [sys.executable, "-c", f"import {mod}; print('{mod} ok')"],
        capture_output=True, text=True,
        cwd='/content/snapfind',
        env=os.environ.copy()
    )
    if f"{mod} ok" in r.stdout:
        print(f"  ✓  {mod}")
    else:
        err = (r.stderr.strip().splitlines() or ["unknown"])[-1]
        print(f"  ✗  {mod} — {err}")
        missing.append(mod)

if missing:
    raise SystemExit(f"Missing: {missing}")

# ── 4. GPU sanity checks ──────────────────────────────────────────────────────
faiss_r = subprocess.run(
    [sys.executable, "-c",
     "import faiss; faiss.StandardGpuResources(); print('FAISS GPU OK')"],
    capture_output=True, text=True, env=os.environ.copy()
)
print(f"\n  {'✓' if 'OK' in faiss_r.stdout else '⚠'}"
      f"  FAISS: {faiss_r.stdout.strip() or faiss_r.stderr.strip()[-100:]}")

ort_r = subprocess.run(
    [sys.executable, "-c",
     "import onnxruntime as ort; p = ort.get_available_providers(); "
     "print('CUDA' if 'CUDAExecutionProvider' in p else 'CPU only')"],
    capture_output=True, text=True, env=os.environ.copy()
)
print(f"  {'✓' if 'CUDA' in ort_r.stdout else '⚠'}"
      f"  ONNX: {ort_r.stdout.strip()}")

# ── 5. Validate required env vars ────────────────────────────────────────────
print("\n🔑 Checking env vars...")
REQUIRED = ["DATABASE_URL", "CELERY_BROKER_URL", "CELERY_RESULT_BACKEND"]
all_ok = True
for var in REQUIRED:
    val = os.environ.get(var, "")
    if val:
        print(f"  ✓  {var} = {val[:40]}...")
    else:
        print(f"  ✗  {var} = NOT SET")
        all_ok = False

if not all_ok:
    raise SystemExit("Set missing env vars in Cell 1 and re-run")

# ── 6. Start Celery worker ────────────────────────────────────────────────────
print("\n🚀 Starting GPU Celery worker...")

env = os.environ.copy()
env["USE_GPU"]    = "true"
env["PYTHONPATH"] = "/content/snapfind"

proc = subprocess.Popen(
    [
        "celery", "-A", "app.workers.celery_worker", "worker",
        "-Q", "photo_processing",
        "--concurrency=2",
        "--pool=prefork",
        "--loglevel=info",
        "--time-limit=300",
        "--soft-time-limit=270",
        "--without-mingle",
        "--without-gossip",
    ],
    stdout=subprocess.PIPE,
    stderr=subprocess.STDOUT,
    text=True,
    cwd='/content/snapfind',
    env=env,
)

def stream_logs(p):
    for line in p.stdout:
        prefix = "  ❌" if any(w in line for w in (
            "ERROR", "Traceback", "ModuleNotFound",
            "ImportError", "ArgumentError", "ValueError"
        )) else "    "
        print(f"{prefix}{line}", end='', flush=True)

threading.Thread(target=stream_logs, args=(proc,), daemon=True).start()

# ── 7. Health check ───────────────────────────────────────────────────────────
time.sleep(12)

if proc.poll() is None:
    print()
    print("=" * 55)
    print("  GPU WORKER RUNNING")
    print("=" * 55)
    print(f"\n  App:   {os.environ.get('APP_URL', '(not set)')}")
    print(f"  Queue: photo_processing")
    print(f"  FAISS: GPU (faiss-gpu-cu{cuda_ver})")
    print(f"  ONNX:  CUDAExecutionProvider")
    print("""
  Flow:
    1. Open APP_URL in browser
    2. Upload photos to an event
    3. Click Process Images
    4. Tasks → Upstash Redis → THIS worker
    5. GPU face detection runs here
    6. finalize_event → clusters written to DB
    7. App shows clusters ✅
    """)
else:
    print(f"\n❌ Worker crashed (exit code {proc.returncode}) — scroll up for traceback")



