"""
# Option A: Run as subprocess (non-blocking, see logs below)
import subprocess, threading

def stream_logs(proc):
    for line in iter(proc.stdout.readline, b''):
        print(line.decode(), end='')

proc = subprocess.Popen(
    [
        "celery", "-A", "app.workers.celery_worker", "worker",
        "-Q", "photo_processing",
        "--concurrency=1",
        "--loglevel=info",
        "--without-heartbeat",
        "--without-gossip",
        "--without-mingle",
    ],
    stdout=subprocess.PIPE,
    stderr=subprocess.STDOUT,
    cwd="/content/snapfind",
)

t = threading.Thread(target=stream_logs, args=(proc,), daemon=True)
t.start()
print("✅ Celery worker started (PID", proc.pid, ")")
print("📋 Logs streaming below...")
print("=" * 60)

# Keep cell alive (shows logs)
import time
while True:
    if proc.poll() is not None:
        print("❌ Worker died! Exit code:", proc.returncode)
        break
    time.sleep(1)


