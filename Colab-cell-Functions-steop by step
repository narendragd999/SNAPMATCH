# CELL 5 — PATCH storage_service TO DOWNLOAD VIA API (critical for Pinggy)
# ══════════════════════════════════════════════════════════════════════════════
"""
# This monkey-patches get_local_temp_path() so instead of trying to connect
# to your local MinIO (unreachable from Colab), it downloads files via your
# FastAPI backend's public URL — which IS reachable.

import requests as _requests
import sys as _sys

# We need to patch BEFORE importing any app code that imports storage_service
_API_BASE = API_BASE  # captured from Cell 3

def _patched_get_local_temp_path(event_id: int, filename: str) -> str:
    """Download file from FastAPI public endpoint → /tmp/snapfind/{event_id}/{filename}"""
    import os, cv2, numpy as np

    tmp_dir  = f"/tmp/snapfind/{event_id}"
    tmp_path = os.path.join(tmp_dir, filename)
    os.makedirs(tmp_dir, exist_ok=True)

    if os.path.exists(tmp_path):
        return tmp_path   # already cached

    # Try public event endpoint (works for optimized/processed files)
    # Raw files are under /storage/events/{event_id}/{filename} (local backend path)
    # We expose them via the owner image endpoint or direct storage mount.
    #
    # Strategy:  GET /storage/events/{event_id}/{filename}
    # This works because FastAPI serves StaticFiles at /storage when STORAGE_BACKEND=local.
    # For minio backend we hit the MinIO public URL directly.
    urls_to_try = [
        f"{_API_BASE}/storage/events/{event_id}/{filename}",   # StaticFiles fallback
        f"{_API_BASE}/storage/{event_id}/{filename}",           # alternate path
    ]

    for url in urls_to_try:
        try:
            resp = _requests.get(url, timeout=30)
            if resp.status_code == 200:
                with open(tmp_path, "wb") as f:
                    f.write(resp.content)
                print(f"⬇️  Downloaded {filename} ({len(resp.content)//1024}KB)")
                return tmp_path
        except Exception as e:
            print(f"⚠️  URL {url} failed: {e}")
            continue

    raise FileNotFoundError(
        f"Could not download {filename} for event {event_id}. "
        f"Tried: {urls_to_try}. "
        f"Check API_BASE and that MinIO/storage is accessible."
    )

def _patched_release_local_temp_path(event_id: int, filename: str) -> None:
    """Keep temp files cached on Colab — disk is free and saves re-downloads."""
    pass  # intentionally no-op on Colab

# Apply patches BEFORE any app imports
import importlib
import app.services.storage_service as _ss
_ss.get_local_temp_path     = _patched_get_local_temp_path
_ss.release_local_temp_path = _patched_release_local_temp_path
print("✅ storage_service patched for Colab download")
"""


